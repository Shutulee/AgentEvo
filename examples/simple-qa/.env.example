# AgentEvo 环境变量配置模板 / Environment Variables Template
# 复制此文件为 .env 并填入实际值 / Copy this file to .env and fill in actual values

# OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here

# 可选：自定义 OpenAI API Base URL / Optional: Custom OpenAI API Base URL
# OPENAI_API_BASE=https://api.openai.com/v1

# 可选：其他 LLM 提供商的配置 / Optional: Other LLM provider configs
# ANTHROPIC_API_KEY=your-anthropic-key
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
